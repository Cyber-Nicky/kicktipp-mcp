# Copy this file to .env and fill in your KickTipp login.
# .env is gitignored and never committed. After the first successful login,
# the session cookie is moved to the macOS Keychain and creds are no longer read on every run.

KICKTIPP_EMAIL=
KICKTIPP_PASSWORD=

# Optional: pin a base URL. Default is https://www.kicktipp.de
# (recon will also probe .com to settle the .de-vs-.com slug question).
KICKTIPP_BASE_URL=https://www.kicktipp.de

# Optional: a specific Tipprunde (community) slug to focus recon on,
# e.g. "bundesliga-tippspiel" or your private round's slug.
# Leave blank to auto-discover from /info/profil/meinetipprunden.
KICKTIPP_COMMUNITY=
